{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loope",
  "version": "0.1.0",
  "identifier": "dev.loope.desktop",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Loope",
        "width": 1240,
        "height": 840,
        "minWidth": 940,
        "minHeight": 620,
        "transparent": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
